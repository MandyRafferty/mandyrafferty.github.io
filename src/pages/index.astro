---
import Layout from '../layouts/Layout.astro';
import '@/styles/global.css';
import headerBg from '../assets/images/pittsburgh-grandview-overlook.jpg';
import saltRobot from '../assets/images/saltRobotThumbnail.png';
import wristBrace from '../assets/images/Granular Jamming Wrist Brace.jpg';
import wrench from '../assets/images/WrenchThumbnail.jpg';
import office from '../assets/images/office.jpg';
import { Button } from "@/components/ui/button";
---


<Layout title="Home - Your Portfolio">
  <a href="/">Home</a>
  <a href="/aboutme/">About</a>
  <a href="/myprojects/">My Projects</a>
  
  <h1>Astro</h1>
  <h1>test</h1>
  <Button>Click me</Button>

  <section class="relative pt-20 pb-20 tracking-widest" id="header">
    <div
      class="absolute inset-0 w-full h-full bg-cover bg-center bg-no-repeat"
      style={`background-image: url(${headerBg.src});`}
    ></div>
    <div class="container mx-auto px-4 relative">
      <div class="flex items-center my-40">
        <div class="w-full md:w-8/12 lg:w-6/12 mx-auto">
          <h1 class="text-7xl mb-6 font-semibold tracking-wide text-center text-white">Mandy Rafferty</h1>
          <p class="text-4xl mb-6 font-bold leading-6 text-center text-white">MECHANICAL ENGINEER</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-gradient-to-br from-blue-100 via-purple-100 to-purple-100" id="features">
		<div class="container mx-auto px-4">
			<div class="flex justify-center">
			<div class="w-full">
				<h2 class="text-4xl font-semibold text-center text-gray-900">Featured Projects</h2>
			</div>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12 max-w-7xl mx-auto">
			<!-- Project 1 -->
			<div class="mt-6 h-full">
				<div class="px-0 py-6 pt-0 bg-white rounded-xl shadow-lg h-full flex flex-col">
				<img 
					src={wristBrace.src} 
					class="w-full rounded-tl-xl rounded-tr-xl object-cover"
					alt="Granular Jamming Wrist Brace"
				/>
				<h3 class="text-xl mx-6 mt-4 mb-3 font-semibold">Granular Jamming Wrist Brace</h3>
				<p class="mx-6 mb-5 leading-6 text-gray-600 flex-grow">Wrist brace that integrates granular jamming to achieve a custom fit in its soft state while providing stabilizing in its rigid state.</p>
				<div class="mt-auto">
					<a href="#" class="inline-block mx-6 px-4 py-2 border border-primary text-primary hover:bg-primary hover:text-white transition-colors rounded font-bold">Learn More</a>
				</div>
				</div>
			</div>
			
			<!-- Project 2 -->
			<div class="mt-6 h-full">
				<div class="px-0 py-6 pt-0 bg-white rounded-xl shadow-lg h-full flex flex-col">
					<img 
					src={saltRobot.src}
					class="w-full rounded-tl-xl rounded-tr-xl object-cover"
					alt="Remote Controlled Salt Spraying Robot"
					/>
				<h3 class="text-xl mx-6 mt-4 mb-3 font-semibold">Remote Controlled Salt Spraying Robot</h3>
				<p class="mx-6 mb-5 leading-6 text-gray-600 flex-grow">Robot that sprays salt remotely to improve safety and increase accessibility for those challenged by manual labor in harsh winter weather.</p>
				<div class="mt-auto">
					<button class="inline-block mx-6 px-4 py-2 border border-primary text-primary hover:bg-primary hover:text-white transition-colors rounded font-bold">Learn More</button>
				</div>
				</div>
			</div>
			
			<!-- Project 3 -->
			<div class="mt-6 h-full">
				<div class="px-0 py-6 pt-0 bg-white rounded-xl shadow-lg h-full flex flex-col">
				<img 
					src={wrench.src} 
					class="w-full rounded-tl-xl rounded-tr-xl object-cover"
					alt="Optimal Design of a Bike Wrench"
				/>
				<h3 class="text-xl mx-6 mt-4 mb-3 font-semibold">Optimal Design of a Bike Wrench</h3>
				<p class="mx-6 mb-5 leading-6 text-gray-600 flex-grow">Reduced material usage in a wrench design through topology optimization using ANSYS Mechanical while achieving design goals.</p>
				<div class="mt-auto">
					<button class="inline-block mx-6 px-4 py-2 border border-primary text-primary hover:bg-primary hover:text-white transition-colors rounded font-bold">Learn More</button>
				</div>
				</div>
			</div>
			</div>
		</div>
		</section>

		<section class="py-20" id="feature">
		<div class="container mx-auto px-4">
			<div class="flex justify-center">
			<div class="w-full md:w-8/12 mx-auto text-center"></div>
			</div>
		</div>
		</section>

		<section class="relative py-40 w-full" id="feature">
		<div class="absolute inset-0 w-full h-full bg-no-repeat bg-center bg-cover bg-fixed"
			 style={`background-image: url(${office.src});`}
		></div>
		<div class="container mx-auto px-4 text-center relative">
			<i class="text-4xl text-center text-gray-700">
			<b>Bringing ideas to life through design & engineering.</b>
			</i>
		</div>
		</section>

		<section class="py-20" id="feature">
		<div class="container mx-auto px-4">
			<div class="flex justify-center">
			<div class="w-full md:w-8/12 mx-auto text-center"></div>
			</div>
		</div>
		</section>
</Layout>